-- Функция создания слайдера (упрощённая)
local function CreateSlider(text, minVal, maxVal, defaultVal, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0.95, 0, 0, 50)
    frame.BackgroundColor3 = Color3.fromRGB(24, 24, 34)
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)
    
    -- вычисляем позицию
    local yPos = 0
    for _, child in pairs(LeftPanel:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextButton") then
            local y = child.Position.Y.Offset + child.Size.Y.Offset
            if y > yPos then
                yPos = y
            end
        end
    end
    frame.Position = UDim2.new(0, 0, 0, yPos + 5)
    frame.Parent = LeftPanel

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 25)
    label.Text = text .. ": " .. defaultVal
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.TextSize = 11
    label.Font = Enum.Font.Gotham
    label.BackgroundTransparency = 1
    label.Parent = frame

    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(0.9, 0, 0, 6)
    bar.Position = UDim2.new(0.05, 0, 0.65, 0)
    bar.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    bar.Parent = frame

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((defaultVal - minVal) / (maxVal - minVal), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0, 255, 180)
    fill.Parent = bar

    local function updateSlider(input)
        local posX = input.Position.X
        local barAbsX = bar.AbsolutePosition.X
        local barSizeX = bar.AbsoluteSize.X
        local pct = math.clamp((posX - barAbsX) / barSizeX, 0, 1)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        local val = math.floor(minVal + (maxVal - minVal) * pct)
        label.Text = text .. ": " .. val
        callback(val)
    end

    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            updateSlider(input)
            local moveCon = UserInputService.InputChanged:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseMovement then
                    updateSlider(inp)
                end
            end)
            local upCon = UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    moveCon:Disconnect()
                    upCon:Disconnect()
                end
            end)
        end
    end)

    leftY = leftY + 55
end

-- Управление машиной
local function StopHijack()
    hijackActive = false
    if hijackConnection then
        hijackConnection:Disconnect()
        hijackConnection = nil
    end
    if hijackVelocity then
        hijackVelocity:Destroy()
        hijackVelocity = nil
    end
    if hijackGyro then
        hijackGyro:Destroy()
        hijackGyro = nil
    end
end

local function StartHijack()
    if hijackActive then
        StopHijack()
    end
    local char = lp.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if not hum or not hum.SeatPart then return end

    local vehicle = hum.SeatPart.Parent
    while vehicle and vehicle.Parent ~= CarsFolder and vehicle.Parent ~= workspace do
        vehicle = vehicle.Parent
    end

    local vehicleRoot = nil
    if vehicle then
        vehicleRoot = vehicle:FindFirstChild("HumanoidRootPart")
        if not vehicleRoot then
            vehicleRoot = vehicle:PrimaryPart
        end
        if not vehicleRoot then
            vehicleRoot = hum.SeatPart
        end
    else
        vehicleRoot = hum.SeatPart
    end

    if not vehicleRoot then return end

    hijackActive = true
    hijackVelocity = Instance.new("BodyVelocity")
    hijackVelocity.MaxForce = Vector3.new(math.huge, 0, math.huge)
    hijackVelocity.Velocity = Vector3.new(0, 0, 0)
    hijackVelocity.Parent = vehicleRoot

    hijackGyro = Instance.new("BodyGyro")
    hijackGyro.MaxTorque = Vector3.new(0, math.huge, 0)
    hijackGyro.CFrame = vehicleRoot.CFrame
    hijackGyro.P = 5000
    hijackGyro.Parent = vehicleRoot

    hijackConnection = RunService.Heartbeat:Connect(function()
        if not hijackActive or not hum.SeatPart or not vehicleRoot.Parent then
            StopHijack()
            return
        end
        local moveDir = Vector3.new(0, 0, 0)
        local cam = Camera.CFrame
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            moveDir = moveDir + cam.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            moveDir = moveDir - cam.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            moveDir = moveDir - cam.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            moveDir = moveDir + cam.RightVector
        end

        if moveDir.Magnitude > 0 then
            moveDir = moveDir.Unit
            hijackVelocity.Velocity = Vector3.new(moveDir.X, 0, moveDir.Z) * flySpeed
            hijackGyro.CFrame = CFrame.new(vehicleRoot.Position, vehicleRoot.Position + Vector3.new(cam.LookVector.X, 0, cam.LookVector.Z))
        else
            hijackVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    end)
end

